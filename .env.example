# ── Base de datos PostgreSQL (Neon / Supabase / Railway Postgres) ─────────────
# Formato: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Autenticación JWT ─────────────────────────────────────────────────────────
# Generá uno seguro con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-random"

# ── Cuenta Gmail para lectura de mails (IMAP) ─────────────────────────────────
# Usá una "contraseña de aplicación" de Google, no la contraseña normal
# Configurar en: https://myaccount.google.com/apppasswords
MAIL_USER="tucuenta@gmail.com"
MAIL_PASSWORD="xxxx xxxx xxxx xxxx"
MAIL_HOST="imap.gmail.com"
MAIL_PORT=993

# ── URL pública del servidor (para links en notificaciones por mail) ──────────
# Railway la setea automáticamente como RAILWAY_PUBLIC_DOMAIN
# Si no usás Railway, setea la URL completa con https://
APP_URL="https://tu-app.railway.app"

# ── Puerto del servidor (Railway lo inyecta automáticamente) ─────────────────
PORT=3000
